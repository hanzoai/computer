# Hanzo IAM (hanzo.id) Configuration
VITE_IAM_URL=https://hanzo.id
VITE_IAM_CLIENT_ID=app-computer

# Commerce API (billing.hanzo.ai)
VITE_COMMERCE_API_URL=https://billing.hanzo.ai

# Site Configuration
VITE_SITE_URL=https://hanzo.computer

# Upstash Redis Configuration (for Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
VITE_API_URL=/api

# Admin Configuration
ADMIN_API_KEY=your-admin-api-key-here
